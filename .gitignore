# next-image-export-optimizer (모든 nextImageExportOptimizer/ 디렉토리 + hash manifest)
# 빌드 시 자동 생성 — sharp/optimizer 버전 변경 시 hash가 일괄 갱신되어 working tree에 churn을 유발.
# Vercel 빌드에서 같은 lockfile로 재생성되므로 추적할 필요 없음.
/public/**/nextImageExportOptimizer/
/public/next-image-export-optimizer-hashes.json
.gstack/

# TypeScript build cache
tsconfig.tsbuildinfo
.vercel

# 외부 조사 보고서(대용량 PDF) — 참고용 로컬 보관, 레포 포함 금지
docs/미술시장 보고서/

# Magazine SQL — gen-magazine-sql.ts 출력. content/magazine-drafts/가 진본,
# .sql은 일회성 빌드 산출물이라 추적 불필요.
scripts/.magazine-sql/

# 디버깅 스크린샷 — 루트에 임시로 떨어지는 PNG/JPG는 추적 안 함
# (실 자산은 public/ 또는 docs/에 보관). 디자인 변경 점검용 working artifact.
/*.png
/*.jpg
/*.jpeg
