{
  "buildCommand": "git fetch --unshallow 2>/dev/null || true && npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "regions": ["icn1"],
  "functions": {
    "app/api/internal/broadcast-dispatch/route.ts": { "maxDuration": 300 },
    "app/api/internal/sms-broadcast-dispatch/route.ts": { "maxDuration": 300 },
    "app/api/internal/reconcile-payments/route.ts": { "maxDuration": 60 },
    "app/api/internal/expire-stale-orders/route.ts": { "maxDuration": 60 },
    "app/api/internal/purge-trash/route.ts": { "maxDuration": 120 },
    "app/api/internal/gsc-sync/route.ts": { "maxDuration": 300 }
  },
  "crons": [
    {
      "path": "/api/internal/purge-trash",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/internal/expire-stale-orders",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/internal/reconcile-payments",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/internal/broadcast-dispatch",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/internal/sms-broadcast-dispatch",
      "schedule": "* * * * *"
    }
  ],
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  }
}
