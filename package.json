{
  "name": "saf-2026",
  "version": "1.0.0",
  "description": "SAF(Seed Art Festival) 2026 공식 웹사이트",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "npm run generate-changelog && next build && next-image-export-optimizer",
    "start": "next start",
    "lint": "eslint . && npm run check:server-button-imports",
    "check:server-button-imports": "node scripts/check-server-button-imports.js",
    "format": "prettier --write .",
    "type-check": "next typegen && tsc --noEmit",
    "format-artworks": "node scripts/format_artworks.js",
    "validate-artworks": "node scripts/validate_artworks.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "email:dev": "email dev --dir emails --port 3030",
    "prepare": "husky install",
    "backup:artwork-images": "node scripts/backup-artwork-images.js",
    "upscale-artwork-images": "node scripts/upscale-artwork-images.js",
    "upscale-artwork-images:apply": "node scripts/upscale-artwork-images.js --apply",
    "backfill:artwork-images:dry": "node scripts/backfill-artwork-image-variants.js",
    "backfill:artwork-images:apply": "node scripts/backfill-artwork-image-variants.js --apply",
    "cleanup:artwork-variants:dry": "node scripts/cleanup-artwork-variants.js",
    "cleanup:artwork-variants:apply": "node scripts/cleanup-artwork-variants.js --apply",
    "sales:dedupe-legacy-csv:dry": "node scripts/deduplicate-legacy-csv-sales.js --verbose",
    "sales:dedupe-legacy-csv": "node scripts/deduplicate-legacy-csv-sales.js --apply --verbose",
    "sales:rebuild-source:dry": "node scripts/rebuild-sales-source-from-csv.js --verbose",
    "sales:rebuild-source": "node scripts/rebuild-sales-source-from-csv.js --apply --verbose",
    "trash:purge:expired:dry": "node scripts/purge-expired-trash.js --dry-run",
    "trash:purge:expired": "node scripts/purge-expired-trash.js",
    "generate-changelog": "node scripts/generate-changelog.js",
    "sync-artworks": "node scripts/sync-artworks-from-db.js"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.94.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tosspayments/tosspayments-sdk": "^2.6.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "embla-carousel-auto-scroll": "^8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.577.0",
    "next": "^16.2.4",
    "next-image-export-optimizer": "^1.20.1",
    "next-intl": "^4.8.3",
    "react": "^19.2.5",
    "react-countup": "^6.4.0",
    "react-dom": "^19.2.5",
    "react-intersection-observer": "^9.5.0",
    "react-kakao-maps-sdk": "^1.2.0",
    "react-lite-youtube-embed": "^2.5.6",
    "react-markdown": "^10.1.0",
    "recharts": "^2.10.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^3.4.0",
    "three": "^0.183.2",
    "yet-another-react-lightbox": "^3.28.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@next/bundle-analyzer": "^16.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.5.1",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "autoprefixer": "^10.4.21",
    "baseline-browser-mapping": "^2.9.15",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "husky": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jiti": "^2.6.1",
    "lint-staged": "^15.0.0",
    "pg": "^8.20.0",
    "playwright": "^1.59.1",
    "postcss": "^8.4.31",
    "prettier": "^3.0.0",
    "react-email": "^5.2.10",
    "typescript": "^5.3.0"
  }
}
