# Kakao Map API Key (Kakao Developers JavaScript 키)
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_api_key_here

# Kakao JavaScript Key (from Kakao Developers - JavaScript Key for KakaoTalk Share)
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_javascript_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional: enable Supabase Storage render/image transformations (can return 401 depending on project setup)
# NEXT_PUBLIC_SUPABASE_RENDER_TRANSFORM=false

# OAuth Redirect Base URL (optional)
# NEXT_PUBLIC_SITE_URL=https://www.saf2026.com

# TossPayments — API 개별 연동 키 (cafe24 경유 기존 MID, 마이그레이션 검증/롤백용)
# NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxx
# TOSS_PAYMENTS_SECRET_KEY=test_sk_xxx
# TOSS_PAYMENTS_WEBHOOK_SECRET=xxx          # 웹훅 검증 시크릿

# TossPayments — 결제위젯 키 (국내 신규 MID — 카드/계좌이체/간편결제)
# NEXT_PUBLIC_TOSS_WIDGET_CLIENT_KEY=test_gck_xxx
# TOSS_PAYMENTS_WIDGET_SECRET_KEY=test_gsk_xxx

# TossPayments — 해외결제 MID (PayPal, Step 2에서 추가 예정)
# NEXT_PUBLIC_TOSS_OVERSEAS_CLIENT_KEY=
# TOSS_PAYMENTS_OVERSEAS_SECRET_KEY=

# 결제 알림 이메일 (Resend)
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=씨앗페 <noreply@saf2026.com>
# NOTIFY_EMAIL_TO=contact@kosmart.org

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# Search Engine Verification (Optional)
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your_google_site_verification_code
# NEXT_PUBLIC_NAVER_VERIFICATION=your_naver_site_verification_code

# ─────────────────────────────────────────────────────────────────
# 오윤 구의동 벽화 시민 청원 (PRD §10.11)
# ─────────────────────────────────────────────────────────────────
# 봇 차단: (a) DB unique constraint(이메일 중복) + (b) IP rate-limit + (c) 영수증 메일 자기검증
# hCaptcha는 운영 결정으로 제거됨 (NEXT_PUBLIC_HCAPTCHA_SITE_KEY/HCAPTCHA_SECRET 사용 안 함)

# 영수증 메일 발송 (RESEND_API_KEY는 위 결제 섹션과 공유)
# PETITION_MAIL_FROM="청원 운영팀 <petition@kosmart.org>"

# (옵션) 마감일·목표 — 미설정 시 lib/petition/constants.ts 기본값 사용
# NEXT_PUBLIC_PETITION_DEADLINE=2026-05-10T23:59:59+09:00
# NEXT_PUBLIC_PETITION_GOAL=10000

# DB 솔트는 PG 설정 변수로 등록 (Studio > SQL Editor 1회):
#   ALTER DATABASE postgres SET app.petition_email_salt = '<랜덤 hex 32B>';
#   ALTER DATABASE postgres SET app.petition_ip_salt    = '<다른 랜덤 hex 32B>';
