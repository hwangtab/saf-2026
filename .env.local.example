# Kakao Map API Key (Kakao Developers JavaScript 키)
NEXT_PUBLIC_KAKAO_MAP_KEY=your_kakao_map_api_key_here

# Kakao JavaScript Key (from Kakao Developers - JavaScript Key for KakaoTalk Share)
NEXT_PUBLIC_KAKAO_JS_KEY=your_kakao_javascript_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# Optional: enable Supabase Storage render/image transformations (can return 401 depending on project setup)
# NEXT_PUBLIC_SUPABASE_RENDER_TRANSFORM=false

# OAuth Redirect Base URL (optional)
# NEXT_PUBLIC_SITE_URL=https://www.saf2026.com

# TossPayments — API 개별 연동 키 (cafe24 경유 기존 MID, 마이그레이션 검증/롤백용)
# NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_xxx
# TOSS_PAYMENTS_SECRET_KEY=test_sk_xxx
# TOSS_PAYMENTS_WEBHOOK_SECRET=xxx          # 웹훅 검증 시크릿

# TossPayments — 결제위젯 키 (국내 신규 MID — 카드/계좌이체/간편결제)
# NEXT_PUBLIC_TOSS_WIDGET_CLIENT_KEY=test_gck_xxx
# TOSS_PAYMENTS_WIDGET_SECRET_KEY=test_gsk_xxx

# TossPayments — 해외결제 MID (PayPal, Step 2에서 추가 예정)
# NEXT_PUBLIC_TOSS_OVERSEAS_CLIENT_KEY=
# TOSS_PAYMENTS_OVERSEAS_SECRET_KEY=

# 결제 알림 이메일 (Resend)
# RESEND_API_KEY=re_xxx
# RESEND_FROM_EMAIL=씨앗페 <noreply@saf2026.com>
# NOTIFY_EMAIL_TO=contact@kosmart.org

# Analytics (Optional)
# NEXT_PUBLIC_GA_ID=your_google_analytics_id

# GA4 Data API — 서버사이드 analytics (admin/analytics 패널, weekly report)
# 인증 우선순위: SA(영구) > OAuth(publish된 앱, 반영구) > ACCESS_TOKEN(개발용 1시간)
#
# [권장] Service Account — 토큰 만료 없음
#   1. GCP Console → IAM → Service Accounts → saf2026-ga-reader@saf2026.iam.gserviceaccount.com
#   2. GA4 Admin → 속성 액세스 관리 → SA 이메일을 "뷰어"로 추가
#      (UI 실패 시: node scripts/ga4-grant-sa-access.js)
#   3. SA JSON을 한 줄로: GA4_SERVICE_ACCOUNT_KEY=$(cat <json-file> | tr -d '\n')
# GA4_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"saf2026",...}
#
# [백업] OAuth refresh token — GCP OAuth consent screen을 "In Production"으로 publish한 뒤 발급
#   1. console.cloud.google.com → APIs & Services → OAuth consent screen → PUBLISH APP
#   2. OAuth Playground(hwangtab@gmail.com)에서 analytics.readonly 스코프로 토큰 발급
# GA4_PROPERTY_ID=531750491
# GA4_OAUTH_CLIENT_ID=your_oauth_client_id
# GA4_OAUTH_CLIENT_SECRET=your_oauth_client_secret
# GA4_OAUTH_REFRESH_TOKEN=your_refresh_token  # publish된 앱이면 만료 없음
#
# [개발] 즉석 access token (1시간, OAuth Playground에서 수동 발급)
# GA4_ACCESS_TOKEN=ya29.xxx

# GSC Data API — 서버사이드 Search Console (cron sync, admin/analytics)
# 인증 우선순위: SA(영구) > OAuth(publish된 앱, 반영구)
#
# [권장] Service Account — GA4_SERVICE_ACCOUNT_KEY와 동일한 SA JSON 재사용 가능
#   1. Search Console → Settings → Users and permissions → Add user
#      → saf2026-ga-reader@saf2026.iam.gserviceaccount.com → "Restricted" 역할 선택
#   2. GA4 SA와 같은 JSON 사용:
#      GSC_SERVICE_ACCOUNT_KEY=$(cat ~/.saf2026-secrets/ga4-service-account.json | tr -d '\n')
# GSC_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"saf2026",...}
#
# [백업] OAuth refresh token (GA4_OAUTH_*와 동일하게 publish된 앱에서 발급)
# GSC_OAUTH_CLIENT_ID=your_oauth_client_id
# GSC_OAUTH_CLIENT_SECRET=your_oauth_client_secret
# GSC_OAUTH_REFRESH_TOKEN=your_refresh_token
#
# Site identifier (등록된 값과 정확히 일치 필요)
# GSC_SITE_URL=sc-domain:saf2026.com

# Search Engine Verification (Optional)
# NEXT_PUBLIC_GOOGLE_VERIFICATION=your_google_site_verification_code
# NEXT_PUBLIC_NAVER_VERIFICATION=your_naver_site_verification_code

# ─────────────────────────────────────────────────────────────────
# 오윤 구의동 벽화 시민 청원 (PRD §10.11)
# ─────────────────────────────────────────────────────────────────
# 봇 차단: (a) DB unique constraint(이메일 중복) + (b) IP rate-limit + (c) 영수증 메일 자기검증
# hCaptcha는 운영 결정으로 제거됨 (NEXT_PUBLIC_HCAPTCHA_SITE_KEY/HCAPTCHA_SECRET 사용 안 함)

# 영수증 메일 발송 (RESEND_API_KEY는 위 결제 섹션과 공유)
# PETITION_MAIL_FROM="청원 운영팀 <petition@kosmart.org>"

# (옵션) 마감일·목표 — 미설정 시 lib/petition/constants.ts 기본값 사용
# NEXT_PUBLIC_PETITION_DEADLINE=2026-05-10T23:59:59+09:00
# NEXT_PUBLIC_PETITION_GOAL=10000

# DB 솔트는 PG 설정 변수로 등록 (Studio > SQL Editor 1회):
#   ALTER DATABASE postgres SET app.petition_email_salt = '<랜덤 hex 32B>';
#   ALTER DATABASE postgres SET app.petition_ip_salt    = '<다른 랜덤 hex 32B>';
